ANTHROPIC_API_KEY=sk-ant-api03-...

# SendGrid SMTP relay — no Gmail access needed
# SMTP_USER must be the literal string "apikey"
# SMTP_PASSWORD is your SendGrid API key (Settings → API Keys)
# EMAIL_FROM must be a verified sender in SendGrid (Settings → Sender Authentication)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASSWORD=SG.xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=NewsAgent <verified-sender@yourdomain.com>
EMAIL_TO=recipient@example.com
